# Optional. Only needed for REST-only features such as comments, versions,
# external file fetches, and remote team resources.
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=

# Optional. Defaults to http://127.0.0.1:3333/auth/callback.
OAUTH_REDIRECT_URI=http://127.0.0.1:3333/auth/callback

# Optional. Defaults are generated locally into .data/ if omitted.
ENCRYPTION_KEY=
SERVER_SHARED_SECRET=
PLUGIN_AUTH_TOKEN=

# Optional server settings.
HOST=127.0.0.1
PORT=3333
DATABASE_PATH=.data/figma-mcp.sqlite
LOG_LEVEL=warn
REQUEST_TIMEOUT_MS=30000

# Optional runtime integration test settings.
# The test suite starts its own MCP server and prints the WebSocket URL/token.
FIGMA_TEST_PLUGIN_TIMEOUT_MS=120000
FIGMA_TEST_PLUGIN_AUTH_TOKEN=
FIGMA_TEST_PORT=

# Safety guard for destructive runtime tests.
# Prefer opening a blank temporary Figma file whose name matches this pattern.
FIGMA_TEST_FILE_NAME_PATTERN=
FIGMA_TEST_ALLOW_ANY_FILE=0
FIGMA_TEST_EDITOR=

# REST/comment integration tests only. Do not use file keys for normal canvas editing.
FIGMA_TEST_FILE_KEY=
FIGMA_TEST_COMMENTS_WRITE=0
FIGMA_RUNTIME_ALLOW_SKIP=0
